# Get BOT_TOKEN from @BotFather on Telegram. (No api_id / api_hash needed.)
BOT_TOKEN=

# Your numeric Telegram user id (message @userinfobot to find it).
# All download requests are reported to this account.
ADMIN_ID=

# How long before the bot deletes the link, status and video messages (seconds)
AUTO_DELETE_SECONDS=300

# Optional: path to a Netscape-format cookies.txt (helps with YouTube bot checks).
# Used automatically only if the file exists.
COOKIES_FILE=/etc/secrets/cookies.txt
